{
  "_comments": [
    "Допустимые терминалы: 'Terminal.app' или 'iTerm'",
    "В значении editor замените 'default' на 'nano', 'vi' или другой терминальный редактор.",
    "Хосты также будут прочитаны из ~/.ssh/config или /etc/ssh_config, если эти файлы доступны",
    "Подробнее о настройке см. на http://fitztrev.github.io/shuttle/"
  ],
  "editor": "default",
  "launch_at_login": false,
  "terminal": "Terminal.app",
  "iTerm_version": "nightly",
  "default_theme": "Homebrew",
  "open_in": "new",
  "show_ssh_config_hosts": false,
  "ssh_config_ignore_hosts": [  ],
  "ssh_config_ignore_keywords": [  ],
  "hosts": [
    {
      "cmd": "ps aux | grep defaults",
      "name": "Grep - открывается с окном, темой и заголовком по умолчанию"
    },
    {
      "Семейные серверы": [
        {
          "cmd": "echo '—->WARNING! Running commands<-- Are you sure? y/n'; read sure; if [ $sure == y ]; then echo running command && ps aux | grep [a]pple; else echo save to history and show... && history -s 'ps aux | grep [a]pple' && osascript -e 'tell application \"System Events\" to keystroke \"p\" using {control down}'; fi",
          "inTerminal": "current",
          "name": "Логи - открыть в текущем активном окне терминала"
        },
        {
          "Серверы Jane": [
            {
              "cmd": "ssh username@blog2.example.com",
              "inTerminal": "tab",
              "name": "SSH blog - открыть во вкладке активного окна",
              "theme": "basic",
              "title": "заголовок вкладки"
            },
            {
              "cmd": "ssh username@shop1.example.com",
              "inTerminal": "new",
              "name": "SSH Shop - открыть в новом окне",
              "theme": "basic",
              "title": "заголовок нового окна"
            }
          ]
        }
      ]
    },
    {
      "Vagrant": [
        {
          "cmd": "ssh vagrant@127.0.0.1 -p 2222 -i ~/.vagrant.d/insecure_private_key",
          "name": "Vagrant - открывается с окном, темой и заголовком по умолчанию"
        }
      ]
    }
  ]
}
